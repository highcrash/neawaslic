# ─── License droplet — environment template ─────────────────────────
# Copy this file to `.env` on the droplet (NEVER commit the filled
# version). docker-compose reads it automatically.
#
#   scp -r infra/license-droplet/ root@<droplet-ip>:/opt/restora-license/
#   ssh root@<droplet-ip>
#   cd /opt/restora-license
#   cp .env.example .env
#   nano .env   # fill the values below

# ─── Postgres (runs inside docker on this droplet) ───────────────────
# Make these strong — even though Postgres doesn't expose a public port,
# defence-in-depth matters if the droplet ever gets compromised.
POSTGRES_USER=license
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=license_prod

# ─── Admin JWT (license-admin UI login) ──────────────────────────────
# Generate:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
LICENSE_ADMIN_JWT_SECRET=CHANGE_ME_base64_48_bytes
LICENSE_ADMIN_JWT_EXPIRES_IN=8h

# ─── Cryptographic secrets — SET ONCE, GUARD FOREVER ─────────────────
# Key-encryption key: wraps ed25519 private signing keys + per-license
# hmacSecrets in the DB. 32 raw bytes, base64.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this requires decrypting + re-wrapping every signing key and
# every hmacSecret in the database — there's no smooth rotation path.
LICENSE_SIGNING_KEK=CHANGE_ME_base64_32_bytes

# Pepper mixed into HKDF when deriving per-license hmacSecret. Same
# rotation constraint: losing this invalidates every license's HMAC.
LICENSE_HMAC_PEPPER=CHANGE_ME_base64_32_bytes

# ─── First-boot admin seed ───────────────────────────────────────────
# Used once when admin_users is empty. After first login, change the
# password from the admin UI — env values are ignored afterwards.
ADMIN_EMAIL=owner@example.com
# bcrypt of your password:
#   node -e "require('bcryptjs').hash('your-password-here', 10).then(console.log)"
ADMIN_PASSWORD_HASH=CHANGE_ME_bcrypt_hash

# ─── Proof TTLs + rate limits (tune if needed) ───────────────────────
LICENSE_PROOF_TTL_SECONDS=86400
LICENSE_PROOF_GRACE_SECONDS=604800
LICENSE_PUBLIC_API_RATE_ACTIVATE=5
LICENSE_PUBLIC_API_RATE_VERIFY=60

# ─── Optional: Envato bulk sync (v1.1) ───────────────────────────────
ENVATO_PERSONAL_TOKEN=
