# Caddy config for the license droplet.
#
# Caddy auto-issues + renews Let's Encrypt certs for each hostname. No
# manual certbot step. Just make sure the A records below point at the
# droplet's public IP BEFORE starting the stack, otherwise ACME HTTP-01
# validation will fail and we'll hit rate limits retrying.
#
# Hostnames:
#   neawaslic.top        → business-site (static, /srv/business)  (apex marketing)
#   www.neawaslic.top    → 301 → neawaslic.top
#   api.neawaslic.top    → license-server:3002  (public license API)
#   admin.neawaslic.top  → license-admin:80     (Vite admin SPA for customers)

api.neawaslic.top {
	encode zstd gzip

	# The server runs behind this proxy — set X-Forwarded-* so req.ip
	# reaches the real client (the license throttler + abuse tracker
	# use CF-Connecting-IP / X-Real-IP / X-Forwarded-For in that order).
	reverse_proxy license-server:3002 {
		header_up X-Real-IP {remote_host}
	}

	# Public license API — all origins allowed (no credentials). Admin
	# CORS for credentialed requests is handled by the server itself
	# using LICENSE_ADMIN_ORIGIN.

	log {
		output file /data/logs/api.log {
			roll_size 10mb
			roll_keep 7
		}
		format console
	}
}

admin.neawaslic.top {
	encode zstd gzip

	reverse_proxy license-admin:80

	# Defence-in-depth headers for the admin SPA. The license-server
	# already sets helmet defaults on its responses; these protect the
	# static bundle.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "same-origin"
		-Server
	}

	log {
		output file /data/logs/admin.log {
			roll_size 10mb
			roll_keep 7
		}
		format console
	}
}

neawaslic.top {
	encode zstd gzip

	# Apex serves the business / portfolio page — single-file static
	# HTML at apps/business-site/index.html, mounted into the Caddy
	# container at /srv/business by docker-compose.
	root * /srv/business
	try_files {path} /index.html
	file_server

	# Helmet-style headers on the marketing page too.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "same-origin"
		-Server
	}
}

# Uncomment once you add a www A/CNAME record at your registrar
# pointing at 167.172.83.158 (or `CNAME neawaslic.top`). Without
# this record, Let's Encrypt rejects the cert with NXDOMAIN.
# www.neawaslic.top {
# 	redir https://neawaslic.top{uri} permanent
# }
