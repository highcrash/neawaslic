// License Server — dedicated schema.
//
// Generator writes to src/generated/prisma-license so this Prisma Client
// is isolated from the Restora POS main API's client (which lives at
// root ../../node_modules/.prisma/client). A single process only ever
// imports one or the other; cross-app type collisions are impossible.
//
// Datasource uses LICENSE_DB_URL — a SEPARATE Postgres cluster (or at
// minimum a separate logical DB + user) from the main API. An outage of
// the main app's DB must not take the license server down, and vice
// versa.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-license"
}

datasource db {
  provider = "postgresql"
  url      = env("LICENSE_DB_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────

enum PurchaseCodeSource {
  IMPORTED  // pulled from CodeCanyon / Envato sales feed
  MANUAL    // issued by admin via UI
  GRANT     // comped / promo — tracked separately from paid sales
}

enum LicenseStatus {
  PENDING    // activate call saw the code but full verification still pending
  ACTIVE     // normal state
  EXPIRED    // server-computed expiry (term licenses; rare for CodeCanyon)
  REVOKED    // admin-revoked; client must refuse on next verify
}

enum CheckAction {
  ACTIVATE
  VERIFY
  DEACTIVATE
  BLOCKED     // abuse throttle fired
  ROTATE      // signing-key rotation event
}

enum AdminRole {
  OWNER
  STAFF
}

// ─────────────────────────────────────────────────────────────────────────
// Product catalogue
// ─────────────────────────────────────────────────────────────────────────

model Product {
  id              String    @id @default(cuid())
  // Short identifier the client bundles at build time, e.g. "restora-pos-cc"
  // or "restora-pos-desktop". Unique globally.
  sku             String    @unique
  name            String
  // Current release version — informational, not enforced against clients.
  version         String
  description     String?
  // CodeCanyon / Envato item ID (numeric) — used by the sales-feed import.
  // Null for non-Envato products.
  envatoItemId    String?
  // Epoch of last successful Envato sync; cron short-circuits if recent.
  envatoLastSyncedAt DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  signingKeys     SigningKey[]
  purchaseCodes   PurchaseCode[]
  licenses        License[]

  @@map("products")
}

// ─────────────────────────────────────────────────────────────────────────
// Purchase codes — the thing a buyer enters during activation
// ─────────────────────────────────────────────────────────────────────────

model PurchaseCode {
  id               String             @id @default(cuid())
  productId        String
  // Plaintext code kept for admin visibility (the buyer will paste it back
  // when reinstalling; they can look it up in the UI). Lookup queries
  // always go through `codeHash` so we never log the raw value.
  code             String             @unique
  // SHA-256(code + LICENSE_HMAC_PEPPER). Indexed for fast activation
  // lookup without exposing the raw code in query logs.
  codeHash         String             @unique
  source           PurchaseCodeSource
  notes            String?

  // One-activation-per-code by default (CodeCanyon Regular License = one
  // end product). Admin can bump this for customers with legitimate
  // multi-install needs (e.g. dev/staging/prod for the same license).
  maxActivations   Int                @default(1)
  usedActivations  Int                @default(0)

  isRevoked        Boolean            @default(false)
  revokedAt        DateTime?
  revokedReason    String?

  envatoBuyer      String?
  envatoSoldAt     DateTime?

  createdAt        DateTime           @default(now())

  product          Product            @relation(fields: [productId], references: [id])
  licenses         License[]

  @@index([productId, isRevoked])
  @@index([codeHash])
  @@map("purchase_codes")
}

// ─────────────────────────────────────────────────────────────────────────
// Licenses — each activation produces one row
// ─────────────────────────────────────────────────────────────────────────

model License {
  id               String         @id @default(cuid())
  purchaseCodeId   String
  productId        String

  // Domain this license is bound to (web edition) OR a sentinel like
  // "desktop:<machineId>" for the POS Desktop. Unique within a purchase
  // code so reactivating the same install is idempotent.
  domain           String
  // Opaque fingerprint the client computes (machine-id + first-boot salt).
  // Used to detect license-file migration attempts.
  fingerprint      String

  // Per-license HMAC secret for request signing. Stored as:
  //   base64(iv).base64(ciphertext).base64(authTag)
  // where ciphertext = AES-256-GCM(LICENSE_SIGNING_KEK, hmacSecret).
  // Derived via HKDF(randomBytes(32), salt=LICENSE_HMAC_PEPPER, info=licenseId).
  hmacSecretEnc    String

  status           LicenseStatus  @default(PENDING)

  activatedAt      DateTime?
  expiresAt        DateTime?
  lastSeenAt       DateTime?
  lastIp           String?

  revokedAt        DateTime?
  revokedReason    String?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  purchaseCode     PurchaseCode   @relation(fields: [purchaseCodeId], references: [id])
  product          Product        @relation(fields: [productId], references: [id])
  logs             CheckLog[]

  // Same license code + domain + fingerprint combo is idempotent — the
  // client can replay activate() after a reinstall without burning an
  // activation slot.
  @@unique([purchaseCodeId, domain, fingerprint])
  @@index([productId, status])
  @@index([domain])
  @@map("licenses")
}

// ─────────────────────────────────────────────────────────────────────────
// Audit log
// ─────────────────────────────────────────────────────────────────────────

model CheckLog {
  id        String      @id @default(cuid())
  licenseId String?
  productId String?
  action    CheckAction
  ip        String?
  userAgent String?
  result    String      // OK | INVALID_CODE | REVOKED | LIMIT | SIG_FAIL | DOMAIN_MISMATCH | ...
  detail    Json?
  at        DateTime    @default(now())

  license   License?    @relation(fields: [licenseId], references: [id])

  @@index([licenseId, at(sort: Desc)])
  @@index([action, at(sort: Desc)])
  @@index([ip, at(sort: Desc)])
  @@map("check_logs")
}

// ─────────────────────────────────────────────────────────────────────────
// Admin accounts for the license-admin UI
// ─────────────────────────────────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(OWNER)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admin_users")
}

// ─────────────────────────────────────────────────────────────────────────
// Signing keys — ed25519 pairs per product. One active, one retiring.
// ─────────────────────────────────────────────────────────────────────────

model SigningKey {
  id                   String    @id @default(cuid())
  productId            String

  // Short human-readable key id embedded in the proof header so clients
  // know which public key to verify against. Needs to outlive rotations
  // (old clients cache the old kid for grace-window days).
  kid                  String    @unique

  // AES-256-GCM(LICENSE_SIGNING_KEK, raw_32_byte_ed25519_seed).
  // Same envelope format as License.hmacSecretEnc.
  ed25519PrivateKeyEnc String

  // base64url of the 32-byte ed25519 public key. Clients bundle this at
  // build time; the /products/:sku/public-key endpoint exposes it so a
  // client with the old kid can discover the new one after rotation.
  ed25519PublicKey     String

  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  // When a new key is issued, the old one sets rotatedAt=now and
  // retiresAt=now+30d. During that window the license server accepts
  // verifies signed under EITHER key; new proofs are issued under the
  // new key only.
  rotatedAt            DateTime?
  retiresAt            DateTime?

  product              Product   @relation(fields: [productId], references: [id])

  @@index([productId, isActive])
  @@map("signing_keys")
}
