# ─── License Server — Environment ───────────────────────────────────────────

NODE_ENV=development
PORT=3002

# Separate Postgres DB — NOT the main API's DB. A license-server outage
# must not imply a main-app outage and vice versa.
LICENSE_DB_URL="postgresql://license:license@localhost:5432/license_dev?schema=public"

# Admin UI origin (the Vite dashboard at apps/license-admin). CORS is
# locked to this origin only.
LICENSE_ADMIN_ORIGIN=http://localhost:5178

# Admin JWT — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
LICENSE_ADMIN_JWT_SECRET=CHANGE_ME_base64_48_bytes
LICENSE_ADMIN_JWT_EXPIRES_IN=8h

# ─── Cryptographic secrets ─────────────────────────────────────────────────
# Key-encryption key: wraps ed25519 private signing keys + per-license
# HMAC secrets in the DB. 32 raw bytes, base64-encoded. Lose it → every
# signing key and every hmacSecret must be rotated.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
LICENSE_SIGNING_KEK=CHANGE_ME_base64_32_bytes

# Pepper mixed into HKDF when deriving per-license hmacSecret. A DB dump
# without this env value yields unusable secrets. Same length + gen as KEK.
LICENSE_HMAC_PEPPER=CHANGE_ME_base64_32_bytes

# ─── First-boot admin seed ─────────────────────────────────────────────────
# Only used when the admin_users table is empty. Change the password via
# the admin UI after first login; the env values are ignored afterwards.
#   node -e "require('bcryptjs').hash('yourpass', 10).then(console.log)"
ADMIN_EMAIL=owner@example.com
ADMIN_PASSWORD_HASH=CHANGE_ME_bcrypt_hash

# ─── Proof TTLs ────────────────────────────────────────────────────────────
# Nominal revalidation cadence — clients refresh every 24h.
LICENSE_PROOF_TTL_SECONDS=86400
# Offline grace — clients operate on cached proof for this long after the
# last successful verify. Envato expects "works offline"; 7 days is a
# reasonable floor.
LICENSE_PROOF_GRACE_SECONDS=604800

# ─── Envato import (optional, v1.1) ────────────────────────────────────────
# Personal token from https://build.envato.com/my-apps/ for bulk purchase-
# code sync. Empty = manual / CSV only.
ENVATO_PERSONAL_TOKEN=

# ─── Rate limits ───────────────────────────────────────────────────────────
LICENSE_PUBLIC_API_RATE_ACTIVATE=5        # per minute per IP
LICENSE_PUBLIC_API_RATE_VERIFY=60         # per minute per license
